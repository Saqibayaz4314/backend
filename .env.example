# ============================================
# CIRO Backend — Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ── AI (OpenRouter) ──────────────────────────
# Get from: https://openrouter.ai/
GEMINI_API_KEY=

# ── Firebase ─────────────────────────────────
# Project ID from Firebase Console
FIREBASE_PROJECT_ID=

# Option A: local file path (for development)
FIREBASE_CREDENTIALS_PATH=./firebase_credentials.json

# Option B: paste entire JSON content (for DigitalOcean / cloud deployment)
# Copy the contents of your service account JSON file and paste it here
FIREBASE_CREDENTIALS_JSON=

# ── External APIs ─────────────────────────────
# OpenWeather: https://openweathermap.org/api
OPENWEATHER_API_KEY=

# Google Maps: https://developers.google.com/maps
GOOGLE_MAPS_API_KEY=

# Serper (Google Search API): https://serper.dev/
SERPER_API_KEY=

# ── X (Twitter) API ──────────────────────────
# Get from: https://developer.twitter.com/
# For real-time crisis signal collection
X_API_KEY=
X_API_SECRET=
X_BEARER_TOKEN=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
# Note: Only X_BEARER_TOKEN is required for v2 API read-only access

# ── Authentication ────────────────────────────
# Gmail: create App Password at myaccount.google.com/apppasswords
SMTP_EMAIL=your_gmail@gmail.com
SMTP_PASSWORD=your_16_char_app_password

# JWT secret — change this in production!
JWT_SECRET=change-this-to-a-random-secret-string

# ── Server ────────────────────────────────────
PORT=8000

# ── Demo / Testing ────────────────────────────
DEMO_MODE=false
SIMULATE_WEATHER_FAILURE=False
SIMULATE_TRAFFIC_FAILURE=False
SIMULATE_GEMINI_FAILURE=False
